#!/bin/bash

# ============================================
# GitSync - Secure repo sync via SSH
# ============================================

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
NC='\033[0m'

# Load config
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/gitsync/config"

if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${RED}✗ Config not found: $CONFIG_FILE${NC}"
    echo "Create it with:"
    echo "  mkdir -p ~/.config/gitsync"
    echo "  echo 'SERVER=your.server.com' >> ~/.config/gitsync/config"
    echo "  echo 'PORT=2222' >> ~/.config/gitsync/config"
    echo "  echo 'LOCAL_PATH=\$HOME/Git' >> ~/.config/gitsync/config"
    exit 1
fi

source "$CONFIG_FILE"

if [ -z "$SERVER" ] || [ -z "$PORT" ] || [ -z "$LOCAL_PATH" ]; then
    echo -e "${RED}✗ Missing config. Required: SERVER, PORT, LOCAL_PATH${NC}"
    exit 1
fi

SSH_CMD="ssh -p $PORT -o ConnectTimeout=10"
RSYNC_FILTER=(--filter=':- .gitignore' --delete -e "$SSH_CMD")

mkdir -p "$LOCAL_PATH"

# Classify a single rsync itemize line.
# Echoes: "added" | "modified" | "deleted" | "" (ignore)
classify_change() {
    local line="$1"
    [[ "$line" == *deleting* ]] && { echo deleted; return; }
    local flags="${line:0:11}"
    # New file/dir: f or d followed by 9 plus signs
    if [[ "$flags" =~ ^[\<\>ch][fd]\+{9}$ ]]; then
        echo added
        return
    fi
    case "${flags:0:1}" in
        '>'|'<'|'c') echo modified ;;
    esac
}

# Run a dry-run and produce per-dir summary.
# Args: SRC DST DEPTH
diff_summary() {
    local src="$1" dst="$2" depth="$3"
    local output exit_code
    output=$(rsync -rin "${RSYNC_FILTER[@]}" --out-format='%i|%n' "$src" "$dst" 2>&1)
    exit_code=$?
    if [ $exit_code -ne 0 ] && [ $exit_code -ne 23 ]; then
        echo -e "${RED}✗ Connection failed (exit code $exit_code):${NC}" >&2
        echo "$output" >&2
        return $exit_code
    fi

    declare -A added modified deleted
    local total_added=0 total_modified=0 total_deleted=0

    while IFS='|' read -r flags path; do
        [[ -z "$path" || "$path" == "./" || "$path" == */ ]] && continue
        local kind
        kind=$(classify_change "$flags$path")
        [[ -z "$kind" ]] && continue

        local dir
        dir=$(echo "$path" | cut -d'/' -f1-"$depth")
        if [[ $(echo "$path" | tr -cd '/' | wc -c) -ge $depth ]]; then
            dir="$dir/"
        fi

        case "$kind" in
            added)    ((added["$dir"]++));    ((total_added++)) ;;
            modified) ((modified["$dir"]++)); ((total_modified++)) ;;
            deleted)  ((deleted["$dir"]++));  ((total_deleted++)) ;;
        esac
    done <<< "$output"

    local total=$((total_added + total_modified + total_deleted))

    if [ $total -eq 0 ]; then
        echo -e "${GREEN}✓ No differences${NC}"
        return 0
    fi

    declare -A all_dirs
    for dir in "${!added[@]}";    do all_dirs["$dir"]=1; done
    for dir in "${!modified[@]}"; do all_dirs["$dir"]=1; done
    for dir in "${!deleted[@]}";  do all_dirs["$dir"]=1; done

    for dir in $(echo "${!all_dirs[@]}" | tr ' ' '\n' | sort); do
        local a=${added["$dir"]:-0}
        local m=${modified["$dir"]:-0}
        local d=${deleted["$dir"]:-0}
        local parts=""
        [[ $a -gt 0 ]] && parts="${parts}${GREEN}+${a}${NC}  "
        [[ $m -gt 0 ]] && parts="${parts}${YELLOW}~${m}${NC}  "
        [[ $d -gt 0 ]] && parts="${parts}${RED}-${d}${NC}  "
        printf "  %-40s %b\n" "$dir" "$parts"
    done

    echo
    printf "  ${DIM}Summary:${NC} ${GREEN}+%d${NC}  ${YELLOW}~%d${NC}  ${RED}-%d${NC}  ${DIM}(%d files)${NC}\n" \
        "$total_added" "$total_modified" "$total_deleted" "$total"

    if [ $exit_code -eq 23 ]; then
        echo -e "${YELLOW}⚠ Some files were skipped:${NC}" >&2
        echo "$output" | grep -E '^rsync:|permission denied|vanished|failed' | head -10 >&2
    fi
    return 0
}

# Run real rsync with live progress + final summary.
# Args: SRC DST LABEL
do_transfer() {
    local src="$1" dst="$2" label="$3"
    echo -e "${BLUE}${label}...${NC}"
    rsync -ah --info=progress2 --info=name0 "${RSYNC_FILTER[@]}" "$src" "$dst"
    local exit_code=$?
    if [ $exit_code -ne 0 ]; then
        echo -e "${RED}✗ Error (exit code $exit_code)${NC}"
        exit $exit_code
    fi
    echo -e "${GREEN}✓ Sync complete${NC}"
}

# Parse depth for status command
DEPTH=1
for arg in "$@"; do
    case "$arg" in
        --depth=*) DEPTH="${arg#*=}" ;;
    esac
done

case "$1" in
    down|pull)
        echo -e "${BLUE}Checking server before pull...${NC}"
        file_count=$(rsync -n --stats -e "$SSH_CMD" "gitsync@$SERVER:." 2>/dev/null | grep "Number of files" | head -1 | grep -oE '[0-9,]+' | tr -d ',')
        if [ -z "$file_count" ] || [ "$file_count" -lt 10 ]; then
            echo -e "${RED}✗ Server appears empty or has very few files ($file_count).${NC}"
            echo -e "${RED}  Refusing to pull to avoid deleting your local ~/Git.${NC}"
            echo -e "${YELLOW}  If this is intentional, remove this check or use rsync manually.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ Server has $file_count files${NC}"
        diff_summary "gitsync@$SERVER:." "$LOCAL_PATH/" "$DEPTH"
        echo
        do_transfer "gitsync@$SERVER:." "$LOCAL_PATH/" "Pulling from server"
        ;;
    up|push)
        diff_summary "$LOCAL_PATH/" "gitsync@$SERVER:." "$DEPTH"
        echo
        do_transfer "$LOCAL_PATH/" "gitsync@$SERVER:." "Pushing to server"
        ;;
    status)
        echo -e "${BLUE}[DRY-RUN] Comparing local vs server...${NC}"
        diff_summary "$LOCAL_PATH/" "gitsync@$SERVER:." "$DEPTH"
        ;;
    *)
        echo "Usage: gitsync [down|up|status] [options]"
        echo ""
        echo -e "  ${GREEN}down${NC}    Pull from server to local"
        echo -e "  ${GREEN}up${NC}      Push from local to server"
        echo -e "  ${GREEN}status${NC}  Show differences (dry-run)"
        echo ""
        echo "Options:"
        echo "  --depth=N   Directory depth for status grouping (default: 1)"
        exit 1
        ;;
esac
