#!/usr/bin/env bash
# Open 4 chat apps in a 2x2 grid on workspace 1.

set -euo pipefail

wait_for_window() {
    local class="$1"
    while ! hyprctl clients -j | jq -e --arg c "$class" '.[] | select(.class == $c)' >/dev/null 2>&1; do
        sleep 0.05
    done
}

split_from() {
    hyprctl dispatch focuswindow "class:$1" >/dev/null
    hyprctl dispatch layoutmsg preselect "$2" >/dev/null
}

# Target layout:
#   top row:    Slack  | Signal
#   bottom row: Brave  | ZapZap
BRAVE=brave-akpamiohjfcnimfljfndmaldlcfphjmp-Default

hyprctl dispatch workspace 1

slack &disown
wait_for_window Slack

split_from Slack r
signal-desktop --password-store="gnome-libsecret" &disown
wait_for_window signal

split_from Slack d
/opt/brave-bin/brave --profile-directory=Default --app-id=akpamiohjfcnimfljfndmaldlcfphjmp &disown
wait_for_window "$BRAVE"

split_from signal d
zapzap &disown
