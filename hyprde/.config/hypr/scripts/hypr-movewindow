#!/bin/bash
# Move the active window; at a horizontal edge, push it to the adjacent
# workspace. Vertical edges are hard stops.
# Usage: hypr-movewindow <l|d|u|r>

direction="$1"

# movewindow silently no-ops at the tree edge, so detect "didn't move" by
# comparing position before and after.
read -r x_before y_before < <(hyprctl activewindow -j | jq -r '"\(.at[0]) \(.at[1])"')
hyprctl dispatch movewindow "$direction"
read -r x_after y_after current_workspace < <(hyprctl activewindow -j | jq -r '"\(.at[0]) \(.at[1]) \(.workspace.id)"')

if [ "$x_before" = "$x_after" ] && [ "$y_before" = "$y_after" ]; then
    case "$direction" in
        l) [ "$current_workspace" -gt 1 ] && hyprctl dispatch movetoworkspace -1 ;;
        r) [ "$current_workspace" -lt 5 ] && hyprctl dispatch movetoworkspace +1 ;;
    esac
fi
