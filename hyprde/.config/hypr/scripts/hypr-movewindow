#!/bin/bash
# Smart window move: swap within workspace, or move to adjacent desktop at edges
# Usage: hypr-movewindow <l|d|u|r>

DIR="$1"

# Get current position before move
INFO=$(hyprctl activewindow -j)
POS_X=$(echo "$INFO" | jq '.at[0]')
POS_Y=$(echo "$INFO" | jq '.at[1]')

# Try moving within workspace
hyprctl dispatch movewindow "$DIR"

# For horizontal moves, if window didn't move, go to adjacent desktop
if [ "$DIR" = "l" ] || [ "$DIR" = "r" ]; then
    NEW_INFO=$(hyprctl activewindow -j)
    NEW_X=$(echo "$NEW_INFO" | jq '.at[0]')
    NEW_Y=$(echo "$NEW_INFO" | jq '.at[1]')

    if [ "$POS_X" = "$NEW_X" ] && [ "$POS_Y" = "$NEW_Y" ]; then
        case "$DIR" in
            l) hyprctl dispatch movetoworkspace -1 ;;
            r) hyprctl dispatch movetoworkspace +1 ;;
        esac
    fi
fi
