#!/usr/bin/env bash
# Launches wlogout with margins computed from the focused monitor so the
# button grid stays centered and square at any resolution.

set -e

if pgrep -x wlogout >/dev/null; then
  pkill -x wlogout
  exit 0
fi

read -r IDX W H < <(hyprctl monitors -j | jq -r 'to_entries[] | select(.value.focused) | "\(.key) \(.value.width) \(.value.height)"')

LAYOUT="${XDG_CONFIG_HOME:-$HOME/.config}/wlogout/layout"
N=$(grep -c '"label"' "$LAYOUT")
COLS=${1:-2}
ROWS=$(( (N + COLS - 1) / COLS ))

SHORT=$(( H < W ? H : W ))
SIZE=$(( SHORT * 15 / 100 ))
GAP=$(( SHORT / 60 ))

AREA_W=$(( SIZE * COLS + GAP * (COLS - 1) ))
AREA_H=$(( SIZE * ROWS + GAP * (ROWS - 1) ))

L=$(( (W - AREA_W) / 2 ))
T=$(( (H - AREA_H) / 2 ))

CSS_SRC="${XDG_CONFIG_HOME:-$HOME/.config}/wlogout/style.css"
CSS_TMP=$(mktemp --suffix=.css)
trap 'rm -f "$CSS_TMP"' EXIT
{ cat "$CSS_SRC"; printf '\nbutton { min-width: %dpx; min-height: %dpx; padding: 0; }\n' "$SIZE" "$SIZE"; } > "$CSS_TMP"

exec wlogout -n -P "$IDX" -C "$CSS_TMP" -b "$COLS" -c "$GAP" -r "$GAP" -T "$T" -B "$T" -L "$L" -R "$L"
