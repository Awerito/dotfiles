#!/bin/bash
# Toggle Spotify in the special:pip workspace.

find_spotify() {
    hyprctl clients -j | jq -r '[.[] | select(.class=="Spotify") | .address] | first // empty'
}

address=$(find_spotify)

if [ -n "$address" ]; then
    hyprctl dispatch togglespecialworkspace pipspoti
    exit 0
fi

spotify-launcher &disown

while [ -z "$address" ]; do
    sleep 0.1
    address=$(find_spotify)
done

read -r monitor_width monitor_height < <(hyprctl monitors -j | jq -r '.[] | select(.focused) | "\(.width) \(.height)"')

hyprctl dispatch resizewindowpixel "exact $((monitor_width * 60 / 100)) $((monitor_height * 60 / 100)),address:$address"
hyprctl dispatch focuswindow "address:$address"
hyprctl dispatch centerwindow
